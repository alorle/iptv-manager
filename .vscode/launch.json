{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Backend (Dev Mode)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}",
      "args": ["-dev"],
      "env": {},
      "showLog": true,
      "preLaunchTask": "Start Vite Dev Server"
    },
    {
      "name": "Launch Backend (Standalone)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}",
      "args": [],
      "env": {},
      "showLog": true
    },
    {
      "name": "Attach to Frontend (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/@/*": "${webRoot}/*"
      }
    },
    {
      "name": "Attach to Frontend (Edge)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/@/*": "${webRoot}/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack Debug",
      "configurations": ["Launch Backend (Dev Mode)", "Attach to Frontend (Chrome)"],
      "presentation": {
        "hidden": false,
        "group": "fullstack",
        "order": 1
      },
      "stopAll": true
    }
  ]
}
